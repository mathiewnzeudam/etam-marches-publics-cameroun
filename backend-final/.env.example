# ============================================================
#  Marché-IA Cameroun — Variables d'environnement
#  Copier ce fichier : cp .env.example .env
#  Puis remplir toutes les valeurs
# ============================================================

# ── Application ────────────────────────────────────────────────
APP_NAME=Marché-IA Cameroun
APP_VERSION=1.0.0
ENV=development
DEBUG=false
# Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGEZ_MOI_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── PostgreSQL ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://marche_ia:secret@localhost:5432/marche_ia_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Claude API (Anthropic) ─────────────────────────────────────
# Obtenir sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=marche_ia_knowledge

# ── Embeddings ─────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768
RAG_TOP_K=8
RAG_MIN_SCORE=0.65

# ── JWT ────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email (alertes) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.cm
SMTP_PASSWORD=votre_mot_de_passe_application
FROM_EMAIL=noreply@marche-ia.cm

# ── WhatsApp (Meta Cloud API) ──────────────────────────────────
WHATSAPP_TOKEN=VOTRE_TOKEN_META
WHATSAPP_PHONE_ID=VOTRE_PHONE_NUMBER_ID

# ── Synchronisation ARMP ───────────────────────────────────────
ARMP_FEED_URL=https://armp.cm/rss
SYNC_INTERVAL_MINUTES=60

# ── Monitoring (optionnel) ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
SENTRY_DSN=

